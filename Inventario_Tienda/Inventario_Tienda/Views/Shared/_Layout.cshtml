<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventario_Tienda</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <h2>Inventario</h2>
                <p>Tienda</p>
            </div>

            <nav class="sidebar-menu">
                <div class="menu-section">Principal</div>

                <a asp-controller="Home" asp-action="Index" class="menu-item">
                    <span>Inicio</span>
                </a>

                <a asp-controller="Venta" asp-action="Registrar" class="menu-item">
                    <span>Registrar venta</span>
                </a>

                <a asp-controller="Venta" asp-action="Historial" class="menu-item">
                    <span>Historial de ventas</span>
                </a>

                <a asp-controller="Producto" asp-action="VerProducto" class="menu-item">
                    <span>Ver productos</span>
                </a>
                <a asp-controller="Cliente" asp-action="Index" class="menu-item">
                    <span>Clientes</span>
                </a>
                <a asp-controller="Categoria" asp-action="Index" class="menu-item">
                    <span>Categorías</span>
                </a>

                <a asp-controller="Proveedor" asp-action="Index" class="menu-item">
                    <span>Proveedores</span>
                </a>
            </nav>
        </aside>

        <div class="main-wrapper">
            <header class="topbar">
                <div>
                    <h1 class="topbar-title">@ViewData["Title"]</h1>
                    <span class="topbar-subtitle">Sistema de inventario</span>
                </div>
            </header>

            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>