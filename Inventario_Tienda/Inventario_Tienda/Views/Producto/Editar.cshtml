@model Inventario_Tienda.Models.Producto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Editar producto";
}

<div class="page-header">
    <h2>Editar producto</h2>
    <p>Modifique la información del producto.</p>
</div>

<div class="form-card mt-4">
    <form asp-action="Editar" method="post">
        @Html.AntiForgeryToken()

        <input asp-for="IdProducto" type="hidden" />

        <div class="mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label"></label>
            <input asp-for="Descripcion" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="PrecioCompra" class="form-label"></label>
            <input asp-for="PrecioCompra" class="form-control" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label asp-for="PrecioVenta" class="form-label"></label>
            <input asp-for="PrecioVenta" class="form-control" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label asp-for="StockActual" class="form-label"></label>
            <input asp-for="StockActual" class="form-control" type="number" />
        </div>

        <div class="mb-3">
            <label asp-for="Estado" class="form-label"></label>
            <select asp-for="Estado" class="form-select">
                <option value="true">Activo</option>
                <option value="false">Inactivo</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="IdCategoria" class="form-label">Categoría</label>
            <select asp-for="IdCategoria" asp-items="ViewBag.Categorias" class="form-select">
                <option value="">-- Seleccione una categoría --</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="IdProveedor" class="form-label">Proveedor</label>
            <select asp-for="IdProveedor" asp-items="ViewBag.Proveedores" class="form-select">
                <option value="">-- Seleccione un proveedor --</option>
            </select>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-main">Actualizar</button>
            <a asp-action="VerProducto" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>