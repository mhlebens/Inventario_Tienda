@model IEnumerable<Inventario_Tienda.Models.Producto>

<div class="table-container">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Producto</th>
                    <th>Precio Compra</th>
                    <th>Precio Venta</th>
                    <th>Stock</th>
                    <th>Estado</th>
                    <th>Categoría</th>
                    <th>Proveedor</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdProducto</td>

                        <td>
                            <div class="product-cell">
                                <div class="product-avatar">
                                    @item.Nombre.Substring(0, 1).ToUpper()
                                </div>
                                <div class="product-info">
                                    <span class="name">@item.Nombre</span>
                                    <span class="meta">@item.Descripcion</span>
                                </div>
                            </div>
                        </td>

                        <td>₡ @item.PrecioCompra.ToString("N2")</td>
                        <td>₡ @item.PrecioVenta.ToString("N2")</td>

                        <td>
                            @if (item.StockActual > 20)
                            {
                                <span class="badge-soft badge-stock-high">Disponible (@item.StockActual)</span>
                            }
                            else if (item.StockActual > 5)
                            {
                                <span class="badge-soft badge-stock-medium">Stock bajo (@item.StockActual)</span>
                            }
                            else
                            {
                                <span class="badge-soft badge-stock-low">Crítico (@item.StockActual)</span>
                            }
                        </td>

                        <td>
                            <span class="badge-soft badge-sale">
                                @(item.Estado ? "Activo" : "Inactivo")
                            </span>
                        </td>

                        <td>@item.NombreCategoria</td>
                        <td>@item.NombreProveedor</td>

                        <td>
                            <div class="table-actions">
                                <button type="button"
                                        class="btn-table-edit btn-edit-producto"
                                        data-id="@item.IdProducto">
                                    Editar
                                </button>

                                <form asp-action="Eliminar" asp-route-id="@item.IdProducto" method="post"
                                      onsubmit="return confirm('¿Desea eliminar este producto?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-table-delete">
                                        Eliminar
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>