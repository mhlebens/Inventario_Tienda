@model Inventario_Tienda.Models.Usuario

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Editar cliente";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-4 mx-auto" style="max-width: 700px;">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-1">Editar cliente</h2>
            <p class="text-muted mb-4">Actualiza la información del cliente.</p>

            <form asp-action="Editar" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="IdUsuario" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control rounded-3" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Telefono" class="form-label fw-semibold"></label>
                    <input asp-for="Telefono" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label asp-for="Correo" class="form-label fw-semibold"></label>
                    <input asp-for="Correo" class="form-control rounded-3" />
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4 rounded-3">Actualizar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-3">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}