@model IEnumerable<Inventario_Tienda.Models.Usuario>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Clientes";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Clientes</h2>
        <p class="page-subtitle">Gestiona los clientes registrados en la tienda.</p>
    </div>

    <div class="page-actions">
        <a asp-action="Crear" class="btn-main">Nuevo cliente</a>
    </div>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success mb-4">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">
        @TempData["Error"]
    </div>
}

<div class="table-container">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdUsuario</td>

                        <td>
                            <div class="product-cell">
                                <div class="product-avatar">
                                    @item.Nombre.Substring(0, 1).ToUpper()
                                </div>
                                <div class="product-info">
                                    <span class="name">@item.Nombre</span>
                                    <span class="meta">Cliente registrado en el sistema</span>
                                </div>
                            </div>
                        </td>

                        <td>
                            <span class="table-title-cell">@item.Telefono</span>
                        </td>

                        <td>
                            <span class="table-title-cell">@item.Correo</span>
                        </td>

                        <td>
                            <div class="table-actions">
                                <a asp-action="Editar"
                                       asp-route-id="@item.IdUsuario"
                                       class="btn-table-edit">
                                    Editar
                                </a>

                                <form asp-action="Eliminar"
                                      asp-route-id="@item.IdUsuario"
                                      method="post"
                                      onsubmit="return confirm('¿Desea eliminar este cliente?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-table-delete">
                                        Eliminar
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>