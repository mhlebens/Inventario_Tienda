@model IEnumerable<Inventario_Tienda.Models.Usuario>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Clientes";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Clientes</h2>
            <p class="text-muted mb-0">Gestiona los clientes registrados en la tienda.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary px-4 rounded-3">+ Nuevo cliente</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Mensaje"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">@TempData["Error"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th>Correo</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.IdUsuario</td>
                                    <td>@item.Nombre</td>
                                    <td>@item.Telefono</td>
                                    <td>@item.Correo</td>
                                    <td class="text-end">
                                        <a asp-action="Editar" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-outline-secondary me-2">
                                            Editar
                                        </a>

                                        <form asp-action="Eliminar" asp-route-id="@item.IdUsuario" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('¿Seguro que deseas eliminar este cliente?');">
                                                Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No hay clientes registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>