@model IEnumerable<Inventario_Tienda.Models.Proveedor>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Proveedores";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Catálogo</h2>
        <p class="page-subtitle">Administra productos, categorías y proveedores desde un mismo módulo.</p>
    </div>

    <div class="page-actions">
        <a asp-action="Crear" class="btn-main">Nuevo proveedor</a>
    </div>
</div>

<div class="module-tabs">
    <a asp-controller="Producto" asp-action="VerProducto" class="module-tab">Productos</a>
    <a asp-controller="Categoria" asp-action="Index" class="module-tab">Categorías</a>
    <a asp-controller="Proveedor" asp-action="Index" class="module-tab active">Proveedores</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success mb-4">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">
        @TempData["Error"]
    </div>
}

<div class="table-container">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Proveedor</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdProveedor</td>

                        <td>
                            <div class="product-cell">
                                <div class="product-avatar">
                                    @item.Nombre.Substring(0, 1).ToUpper()
                                </div>
                                <div class="product-info">
                                    <span class="name">@item.Nombre</span>
                                    <span class="meta">Proveedor registrado en el sistema</span>
                                </div>
                            </div>
                        </td>

                        <td>@item.Telefono</td>
                        <td>@item.Correo</td>

                        <td>
                            <div class="table-actions">
                                <a asp-action="Editar"
                                       asp-route-id="@item.IdProveedor"
                                       class="btn-table-edit">
                                    Editar
                                </a>

                                <form asp-action="Eliminar"
                                      asp-route-id="@item.IdProveedor"
                                      method="post"
                                      onsubmit="return confirm('¿Desea eliminar este proveedor?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-table-delete">
                                        Eliminar
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>