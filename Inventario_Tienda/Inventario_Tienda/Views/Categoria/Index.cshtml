@model IEnumerable<Inventario_Tienda.Models.Categoria>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Categorías";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Catálogo</h2>
        <p class="page-subtitle">Administra productos, categorías y proveedores desde un mismo módulo.</p>
    </div>

    <div class="page-actions">
        <a asp-controller="Producto" asp-action="Crear" class="btn-main">Nuevo producto</a>
    </div>
</div>

<div class="module-tabs">
    <a asp-controller="Producto" asp-action="VerProducto" class="module-tab">Productos</a>
    <a asp-controller="Categoria" asp-action="Index" class="module-tab active">Categorías</a>
    <a asp-controller="Proveedor" asp-action="Index" class="module-tab">Proveedores</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success mb-4">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">
        @TempData["Error"]
    </div>
}

<div class="category-grid">
    <div class="category-form-card">
        <h4>Nueva categoría</h4>
        <p class="category-helper">Agrega una categoría para organizar mejor el catálogo de productos.</p>

        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Nombre de la categoría</label>
                <input type="text"
                       name="Nombre"
                       class="form-control"
                       placeholder="Ej. Skincare"
                       required />
            </div>

            <button type="submit" class="btn-main w-100">
                Guardar categoría
            </button>
        </form>
    </div>

    <div class="category-list-card">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div>
                <h4 class="mb-1">Categorías registradas</h4>
                <p class="category-helper mb-0">Consulta y administra las categorías disponibles.</p>
            </div>

            <span class="badge-soft badge-sale">@Model.Count() categorías</span>
        </div>

        <div id="categoryListContainer">
            @await Html.PartialAsync("_CategoriaListPartial", Model)
        </div>
    </div>

    <div class="modal fade" id="categoriaModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" id="categoriaModalContent">
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/categoria.js"></script>
}